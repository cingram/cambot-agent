ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
CHANNELS=cli,web
CAMBOT_DB_PATH=./store/cambot.sqlite
ADMIN_KEY=

# Memory mode: markdown (flat files only), database (SQLite facts only), both (default)
MEMORY_MODE=both

# Google Workspace Integration (workspace-mcp)
# Set all three to enable Google tools (Gmail, Calendar, Tasks, Drive, etc.)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
USER_GOOGLE_EMAIL=
WORKSPACE_MCP_PORT=8000
