{
  "cambot-agent": {
    "type": "stdio",
    "command": "node",
    "args": ["${SCRIPT_DIR}/ipc-mcp-stdio.js"],
    "env": {
      "CAMBOT_AGENT_CHAT_JID": "${CHAT_JID}",
      "CAMBOT_AGENT_GROUP_FOLDER": "${GROUP_FOLDER}",
      "CAMBOT_AGENT_IS_MAIN": "${IS_MAIN}"
    }
  },
  "workflow-builder": {
    "type": "stdio",
    "command": "node",
    "args": ["${SCRIPT_DIR}/workflow-mcp-stdio.js"],
    "env": {
      "CAMBOT_AGENT_GROUP_FOLDER": "${GROUP_FOLDER}",
      "CAMBOT_AGENT_IS_MAIN": "${IS_MAIN}"
    }
  },
  "google-workspace": {
    "type": "http",
    "url": "http://host.docker.internal:${WORKSPACE_MCP_PORT}/mcp"
  }
}
